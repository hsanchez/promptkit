# Copy this file to .env and fill in your values.
# e.g., cp .env.example .env
# .env is git-ignored — never commit real keys.

# Anthropic (required for AnthropicProvider)
ANTHROPIC_API_KEY=

# OpenAI (required for OpenAIProvider)
# OPENAI_API_KEY=

# Google (required for GeminiProvider)
# GOOGLE_API_KEY=
